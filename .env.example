# Variables d'environnement Bad's Club app.
# Copie ce fichier en `.env.local` et remplis les valeurs pour ton environnement.
# `.env.local` est gitignored — ne JAMAIS committer de secrets.

# ─── Notifications ─────────────────────────────────────────────────────────
# URL du webhook N8N qui orchestre email/SMS/Slack via Brevo.
# Si absent en dev, les events restent dans le feed in-app uniquement.
N8N_NOTIF_WEBHOOK=

# ─── Firebase (à câbler en prod) ───────────────────────────────────────────
# NEXT_PUBLIC_* sont exposés au client : pas de secrets ici.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Côté serveur uniquement (admin SDK, à ne JAMAIS exposer en client)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ─── Stripe (paiements) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Brevo (email + SMS) ───────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SMS_SENDER=BADS_CLUB
